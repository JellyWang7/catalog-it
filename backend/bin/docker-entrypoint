#!/bin/bash -e

# If running the Rails server, create or migrate the database first.
# Match: ./bin/rails server [...]  OR  ./bin/thrust ./bin/rails server [...]
rails_server=false
if [[ "${1:-}" == "./bin/rails" && "${2:-}" == "server" ]]; then
  rails_server=true
elif [[ "${1:-}" == "./bin/thrust" && "${2:-}" == "./bin/rails" && "${3:-}" == "server" ]]; then
  rails_server=true
fi

if [[ "${rails_server}" == true ]]; then
  ./bin/rails db:prepare
  # Solid Queue tables live in db/queue_schema.rb; db:prepare only runs db/migrate on primary.
  # Without this, Active Storage enqueues PurgeJob/AnalyzeJob → INSERT into solid_queue_jobs → 500.
  ./bin/rails db:ensure_solid_queue
fi

exec "${@}"
