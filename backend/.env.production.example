# Rails
RAILS_ENV=production
# Do not set RAILS_MASTER_KEY for EC2 Docker unless you use encrypted credentials with a matching key.
# This project expects SECRET_KEY_BASE and DB/AWS env vars only (see DEPLOY.md).
SECRET_KEY_BASE=replace_with_generated_secret
RAILS_LOG_LEVEL=info
RAILS_MAX_THREADS=5
WEB_CONCURRENCY=1

# CORS
FRONTEND_URL=https://replace-with-your-cloudfront-domain

# PostgreSQL (RDS)
DATABASE_HOST=replace-with-rds-endpoint
DATABASE_PORT=5432
DATABASE_NAME=catalogit_production
DATABASE_USERNAME=catalogit
CATALOGIT_DATABASE_PASSWORD=replace_with_db_password

# Active Storage (S3)
ACTIVE_STORAGE_SERVICE=amazon
AWS_ACCESS_KEY_ID=replace_with_access_key_id
AWS_SECRET_ACCESS_KEY=replace_with_secret_access_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=replace-with-s3-bucket-name
