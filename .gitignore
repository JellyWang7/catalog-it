# See https://help.github.com/articles/ignoring-files for more about ignoring files.

# Documentation (NEVER push to GitHub)
/docs/
/CatalogIt-UpdatedProjectCharter_etc.pdf
*.docx

# Dependencies
node_modules/
vendor/bundle/

# Environment variables
.env
.env.*
!.env.example
!**/.env.example

# Deployment/runtime secrets
/backend/.env.production
/backend/.kamal/secrets*
/infra/terraform.tfvars
/infra/*.tfstate
/infra/*.tfstate.*
/infra/.terraform/
/infra/crash.log
/infra/*.tfplan

# Private key/cert material
*.pem
*.key

# Ignore bundler config.
/.bundle
/backend/gems/
/backend/specifications/
/backend/cache/
/backend/extensions/
/backend/plugins/

# Ignore all logfiles and tempfiles.
/backend/log/*
/backend/tmp/*
!/backend/log/.keep
!/backend/tmp/.keep
!/backend/tmp/pids/.keep

# Ignore pidfiles, but keep the directory.
/backend/tmp/pids/*
!/backend/tmp/pids/.keep

# Ignore storage files
/backend/storage/*
!/backend/storage/.keep
/backend/tmp/storage/*
!/backend/tmp/storage/.keep

# Ignore master key for decrypting credentials and more.
/backend/config/master.key
backend/config/master.key

# Ignore database configuration (contains passwords)
/backend/config/database.yml
backend/config/database.yml

# Ignore database backups
/backend/config/database.yml.backup
backend/config/database.yml.backup

# Ignore uploaded files
/backend/public/uploads/

# Rails cache
/backend/public/assets
/backend/public/packs
/backend/public/packs-test

# Frontend (when you add it)
/frontend/node_modules/
/frontend/dist/
/frontend/.env
/frontend/.env.local
/frontend/.env.*.local

# Build outputs
*.log
*.swp
*.swo
*~

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.code-workspace
/catalog-it.code-workspace

# Coverage
/backend/coverage/

# Testing
/backend/test/tmp/
/backend/test/version_tmp/
/frontend/test-results/
/backend/tmp/cache/bootsnap/
/backend/tmp/cache/bootsnap/**

# Yarn
yarn-error.log

# Database
*.sqlite3
*.sqlite3-journal
*.sqlite3-*
